@page
@model StudentActivityPortal.Pages.IndexModel
@{
    ViewData["Title"] = "Student Activity Portal Home";
}

<h2>Student Activity Portal</h2>

<form method="post">
    <div>
        <label for="Name">Enter your name:</label>
        <input asp-for="Name" />
    </div>

    <br />

    <button type="submit">Submit</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <br />
    <p style="color: blue;">@Model.Message</p>
}

<br />
<a asp-page="/Activities">View Activities</a>