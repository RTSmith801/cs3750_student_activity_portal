@model IEnumerable<StudentActivityPortal.Models.Activity>

<h2>Activities</h2>

<a asp-action="Create" class="btn btn-primary">Add Activity</a>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr style="@(item.Id == ViewBag.SelectedActivityId ? "background-color: lightyellow;" : "")">
                <td>@item.Title</td>
                <td>@item.ActivityDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>